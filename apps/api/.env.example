DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.sa-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
JWT_SECRET="sua-chave-secreta-aqui"
PORT=3333
FRONTEND_URL="http://localhost:3000"

# IA para importação de extratos — preencha UM dos dois abaixo.
# Se OPENAI_API_KEY estiver presente, ela tem prioridade.
# Caso contrário, GROQ_API_KEY é usada (gratuito em https://console.groq.com).
OPENAI_API_KEY=
GROQ_API_KEY=

# Roadmap — issues do GitHub como fonte de dados.
# GITHUB_TOKEN é opcional mas evita rate limit (60 req/h sem token, 5000 com token).
# Crie em: https://github.com/settings/tokens (permissão: public_repo leitura)
GITHUB_REPO_OWNER="juninhos-comunidade"
GITHUB_REPO_NAME="Cifrinho"
GITHUB_TOKEN=
